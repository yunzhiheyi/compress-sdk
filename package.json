{
  "name": "compress-sdk-plus",
  "version": "1.0.14",
  "description": "Browser-side media compression SDK supporting video and image compression",
  "type": "module",
  "main": "./index.ts",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./index.d.ts"
    },
    "./video": "./core/video/index.ts",
    "./image": "./core/image/index.ts"
  },
  "files": [
    "core/**/*.ts",
    "index.ts",
    "index.d.ts",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "dev": "vite build",
    "build": "vite build"
  },
  "keywords": [
    "compress",
    "compression",
    "video",
    "image",
    "webcodecs",
    "watermark",
    "nuxt",
    "vue"
  ],
  "dependencies": {
    "@jsquash/avif": "^2.1.0",
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/png": "^3.1.0",
    "@jsquash/resize": "^2.1.0",
    "@jsquash/webp": "^1.5.0",
    "compress-sdk-plus": "1.0.14",
    "mediabunny": "^1.40.1"
  },
  "peerDependencies": {
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yunzhiheyi/compress-sdk"
  },
  "bugs": {
    "url": "https://github.com/yunzhiheyi/compress-sdk/issues"
  },
  "homepage": "https://github.com/yunzhiheyi/compress-sdk#readme",
